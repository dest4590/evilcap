[Unit]
Description=evilcap api.rest service.
Documentation=https://github.com/dest4590/evilcap
Wants=network.target
After=network.target

[Service]
Type=simple
PermissionsStartOnly=true
ExecStart=/usr/local/bin/evilcap -no-colors -eval "set events.stream.output /var/log/evilcap.log; api.rest on"
Restart=always
RestartSec=30

[Install]
WantedBy=multi-user.target